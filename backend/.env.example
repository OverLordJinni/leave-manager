# ─── Required ─────────────────────────────────────────────────────────────────

# Neon Postgres connection string.
# On Vercel this is auto-injected by the Neon Marketplace integration as
# DATABASE_URL (use the POOLED connection string). For local dev, copy the
# pooled connection string from the Neon dashboard.
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require

# Secret used to sign session + WebAuthn-challenge cookies (HMAC-SHA256).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=generate_a_random_64_char_hex_string_here

# The app's own public URL. Required in production — used for:
#   • WebAuthn relying-party ID + expected origin (passkeys)
#   • CORS origin (only matters for split/cross-origin local dev)
# Production: https://your-domain.com   Local: http://localhost:5173
FRONTEND_URL=https://your-domain.com

# ─── Optional ──────────────────────────────────────────────────────────────────

# Restrict signup to a single email. If unset, the first account to sign up wins
# and all further signups are blocked (single-user app).
# ADMIN_EMAIL=you@example.com

# ─── Local dev only (Vercel sets NODE_ENV automatically) ───────────────────────
NODE_ENV=development
PORT=3001
