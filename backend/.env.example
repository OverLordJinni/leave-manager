# ─── Required ─────────────────────────────────────────────────────────────────

# Supabase project URL (from Supabase dashboard → Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase SERVICE ROLE key — NEVER expose this to the frontend
# Found at: Supabase dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_KEY=eyJhbGc...

# Secret token to unlock the app (you choose this — share it with no one)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_TOKEN=generate_a_random_64_char_hex_string_here

# Secret for signing session cookies
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=generate_another_random_64_char_hex_string_here

# Your Netlify frontend URL — required in production for CORS
FRONTEND_URL=https://your-app.netlify.app

# ─── Auto-set by Render ────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
